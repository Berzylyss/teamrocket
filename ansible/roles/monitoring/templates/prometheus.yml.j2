global:
  scrape_interval:     15s
  evaluation_interval: 15s

scrape_configs:

  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "node"
    static_configs:
      - targets:
{% for host in groups['web'] %}
          - "{{ host }}:9100"
{% endfor %}
{% for host in groups['ftp'] %}
          - "{{ host }}:9100"
{% endfor %}
        labels:
          env: "production"
          project: "{{ project }}"
